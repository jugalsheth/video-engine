# Zero-cost defaults (recommended)
ZERO_COST_MODE=true
JUMP_CUTS=true
GLOBAL_FX=false
JUMP_CUT_MIN_SILENCE=0.12
JUMP_CUT_MAX_REMOVE_RATIO=0.35
WHISPER_MODEL=small
BROLL_MODE=svg
SKIP_STOCK_FETCH=true
USE_DESIGN_AGENT=false

# Voice + music polish
VOICE_ENHANCE=true
VOICE_DENOISE_STRENGTH=-25

# Optional — only for ad-lib videos without a matched script
# ANTHROPIC_API_KEY=
# USE_DESIGN_AGENT=true

# Optional — AI topical B-roll + custom visuals (fal.ai via httpx)
# FAL_KEY=
# AI_IMAGES=true
# AI_IMAGE_MODEL=flux-schnell
# AI_IMAGE_MAX_PER_VIDEO=8
# BROLL_MODE=ai

# Optional stock (free tier APIs)
# PEXELS_API_KEY=
# PIXABAY_API_KEY=

# Script archive + notifications
# SCRIPTS_ARCHIVE_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
